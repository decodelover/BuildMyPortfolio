# =========================================================================
# BuildMyPortfolio Environment Variables Template
# Copy this file to .env.local and populate with your configuration keys
# Do NOT commit your actual .env.local file to version control
# =========================================================================

# -------------------------------------------------------------------------
# Firebase Client SDK Configuration (Exposed to Browser)
# -------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_app_id_here
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-your_measurement_id

# -------------------------------------------------------------------------
# Firebase Admin SDK Configuration (Server-Side Secrets)
# -------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
# Note: Ensure the private key contains literal newline characters (\n)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ...\n-----END PRIVATE KEY-----\n"

# -------------------------------------------------------------------------
# Gemini AI Configuration
# -------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -------------------------------------------------------------------------
# Payment Gateway Integrations
# -------------------------------------------------------------------------
# Paystack API Keys
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Flutterwave API Keys
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_ENCRYPTION_KEY=FLWENCK_TEST-xxxxxxxxxxxx

# -------------------------------------------------------------------------
# Posthog Analytics Integration
# -------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_SECRET_KEY=ph_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------------------
# Application URLs
# -------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
