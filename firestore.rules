rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the user owns the record by UID match
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the request user matches document userId
    function isDocOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Check if the user is an administrator
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // Rules for the users collection
    match /users/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Rules for billing: subscriptions
    match /subscriptions/{subscriptionId} {
      allow read: if isDocOwner() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Rules for billing: customers
    match /customers/{customerId} {
      allow read: if isDocOwner() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Rules for billing: payments
    match /payments/{paymentId} {
      allow read: if isDocOwner() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Rules for billing: billing_events
    match /billing_events/{eventId} {
      allow read: if isDocOwner() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Rules for billing: usage
    match /usage/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Rules for billing: plans (Public read for tier comparison)
    match /plans/{planId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Rules for billing: feature_flags
    match /feature_flags/{flagId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Rules for billing: invoices
    match /invoices/{invoiceId} {
      allow read: if isDocOwner() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Rules for the notifications collection
    match /notifications/{notificationId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isDocOwner() || isAdmin();
    }

    // Rules for the supportTickets collection
    match /supportTickets/{ticketId} {
      allow create: if isAuthenticated();
      allow read, update: if isDocOwner() || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Rules for the contactMessages collection (Public contact form)
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    
    // Rules for the websiteBuilders collection
    match /websiteBuilders/{builderId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isDocOwner() || isAdmin();
    }

    // Rules for the portfolios collection
    match /portfolios/{portfolioId} {
      allow create: if isAuthenticated();
      allow read: if true; // Public view for published portfolios
      allow update, delete: if isDocOwner() || isAdmin();
    }
    
    // Rules for the websitePlans collection
    match /websitePlans/{planId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isDocOwner() || isAdmin();
    }
    
    // Rules for the generationJobs collection
    match /generationJobs/{jobId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isDocOwner() || isAdmin();
    }
    
    // Rules for the websiteManifests collection
    match /websiteManifests/{manifestId} {
      allow create: if isAuthenticated();
      allow read: if true; // Public read for rendering published portfolio sites
      allow update, delete: if isDocOwner() || isAdmin();
    }

    // Rules for the public testimonials collection
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Default fallback to deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
