rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the user owns the record
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if the user is an administrator
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    // Rules for the users collection
    match /users/{userId} {
      // Any authenticated user can create their own profile document
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Profiles can be read by their owners or administrators
      allow read: if isOwner(userId) || isAdmin();
      
      // Update rule protecting role, plan, status, and creation timestamps from user edits
      allow update: if isOwner(userId) 
        ? (
            !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'currentPlan', 'isSuspended', 'createdAt'])
          )
        : isAdmin();
        
      // Only administrators can remove profiles
      allow delete: if isAdmin();
    }
    
    // Rules for the notifications collection
    match /notifications/{notificationId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Rules for the supportTickets collection
    match /supportTickets/{ticketId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Rules for the websiteBuilders collection
    match /websiteBuilders/{builderId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Rules for the portfolios collection
    match /portfolios/{portfolioId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Rules for the websitePlans collection
    match /websitePlans/{planId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Rules for the generationJobs collection
    match /generationJobs/{jobId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Rules for the websiteManifests collection
    match /websiteManifests/{manifestId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Rules for the public testimonials collection
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Default fallback to deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
