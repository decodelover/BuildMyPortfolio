rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User storage folder: Users can read and write only their own files
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default fallback: Deny all unhandled paths
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
